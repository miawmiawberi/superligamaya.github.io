// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to everyone
    match /{document=**} {
      allow read: if true;
    }

    // Allow write access only to authenticated users
    match /teams/{teamId} {
      allow write: if request.auth != null;
    }

    match /matches/{matchId} {
      allow write: if request.auth != null;
    }
  }
}
